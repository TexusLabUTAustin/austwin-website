{
  "buildCommand": "npm run build -w apps/web",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_CITYFORESIGHT_API_HOST/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
