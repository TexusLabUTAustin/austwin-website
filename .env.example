
# Copy to .env and fill in values ( .env is gitignored )
# Free Census API key: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Cesium 3D globe (CityForesight). Optional — without a token the globe still
# renders tract heat columns on a tokenless base; a free token adds real terrain
# elevation + 3D OSM buildings. Get one: https://ion.cesium.com/tokens
VITE_CESIUM_ION_TOKEN=

# Local dev ports (use 8010/8011/8012 if port 8000 is taken by Cursor or another app)
CITYFORESIGHT_DEV_PORT=8010
URBANSENSE_DEV_PORT=8011
CITYGUIDE_DEV_PORT=8012
THERMALSCAPE_DEV_PORT=8013

# Optional CityForesight overrides (defaults are fine for local dev)
# CITYFORESIGHT_ADMIN_TOKEN=dev-admin-token
# CITYFORESIGHT_FETCH_NLCD=true
# CITYFORESIGHT_GEOCODE_USER_AGENT=AusTwin-CityForesight/0.1
# CITYFORESIGHT_URBANSENSE_URL=http://localhost:8011
# CITYFORESIGHT_ERCOT_ENABLED=true
# CITYFORESIGHT_ANOMALY_ENRICH=true
# Flood scores use USGS NWIS IV gauges + Open-Meteo precip (no key required).
# Grid scores use ERCOT supply-demand dashboard JSON (no key required).

# UrbanSense (Phase 2 anomaly detection + ontology)
URBANSENSE_CITYFORESIGHT_URL=http://localhost:8010
URBANSENSE_ADMIN_TOKEN=dev-admin-token

# CityGuide (Agent 3 — operator Q&A chatbot). Local open-source LLM + RAG, $0 / no tokens.
# It grounds answers on the two services below plus its knowledge base.
CITYGUIDE_CITYFORESIGHT_URL=http://localhost:8010
CITYGUIDE_URBANSENSE_URL=http://localhost:8011
# Optional overrides (defaults are fine):
# CITYGUIDE_MODEL_REPO=Qwen/Qwen2.5-3B-Instruct-GGUF
# CITYGUIDE_MODEL_FILE=qwen2.5-3b-instruct-q4_k_m.gguf
# CITYGUIDE_RETRIEVAL_THRESHOLD=0.28
